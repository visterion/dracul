#!/bin/sh
# .githooks/pre-commit — WARNING ONLY, never blocks.
set -eu

CHANGED_FILES=$(git diff --cached --name-only)

# 1. Guard: never let a private/gitignored file get committed to this PUBLIC repo.
PRIVATE=$(echo "$CHANGED_FILES" | grep -iE '(^|/)(CLAUDE\.md|DESIGN\.md|DRACUL-PLAN\.md|GUI-MOCKUP\.md|vistierie-plan\.md)$|^docs/' || true)
if [ -n "$PRIVATE" ]; then
  echo "  BLOCKED-BY-CONVENTION: a private/gitignored file is staged:"
  echo "$PRIVATE" | sed 's/^/     /'
  echo "   Unstage it (git restore --staged <file>). These stay local — never commit."
fi

# 2. Nudge: structural change but local CLAUDE.md may be stale.
STRUCTURAL=$(echo "$CHANGED_FILES" | grep -E '(pom\.xml|package\.json|Dockerfile|\.ya?ml)' || true)
NEW=$(git diff --cached --diff-filter=A --name-only | grep -E '\.(java|ts|tsx|js|vue|py)$' || true)
DELETED=$(git diff --cached --diff-filter=D --name-only | grep -E '\.(java|ts|tsx|js|vue|py)$' || true)
if [ -n "$STRUCTURAL" ] || [ -n "$NEW" ] || [ -n "$DELETED" ]; then
  if [ -f CLAUDE.md ] && [ -n "$(find . -maxdepth 4 \( -name '*.java' -o -name '*.ts' -o -name '*.vue' -o -name '*.py' \) -newer CLAUDE.md 2>/dev/null | head -1)" ]; then
    echo "  Structure changed but local CLAUDE.md looks stale."
    echo "   Run: 'Update CLAUDE.md to reflect recent changes'"
  fi
fi

exit 0
