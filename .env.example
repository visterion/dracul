# Copy to .env on LXC 102 and fill in. Never commit the real .env.
# Tenant token: returned once by `POST /admin/tenants {"name":"dracul"}` (see runbook).
VISTIERIE_TENANT_TOKEN=
# Admin token: the plaintext whose BCrypt hash is Vistierie's VISTIERIE_ADMIN_TOKEN_HASH.
VISTIERIE_ADMIN_TOKEN=
# Shared secret for Strigoi-Insider tool + completion webhooks (any strong random string).
STRIGOI_INSIDER_TOKEN=
# SEC requires a real identifying contact on EDGAR requests.
DRACUL_EDGAR_USER_AGENT=dracul-research/1.0 your-name your-email@example.com
# Cloudflare Access — REQUIRED outside dev/test (app refuses to start if blank).
# Full team-domain URL; JWKS is read from <team-domain>/cdn-cgi/access/certs.
DRACUL_CLOUDFLARE_TEAM_DOMAIN=https://<team>.cloudflareaccess.com
# Application Audience (AUD) tag of the Cloudflare Access app for this host.
DRACUL_CLOUDFLARE_AUD=
# Agora MCP gateway — Dracul's prices/OHLC provider (required from Slice 7a).
# Deploy Agora in-cluster FIRST, then Dracul. Blank token only if Agora runs no-auth.
DRACUL_AGORA_BASE_URL=http://agora:8080
DRACUL_AGORA_TOKEN=
