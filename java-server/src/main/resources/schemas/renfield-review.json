{
  "type": "object",
  "required": ["proposals", "market_note"],
  "properties": {
    "proposals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["symbol", "action", "confidence", "rationale"],
        "properties": {
          "symbol": {"type": "string"},
          "action": {"type": "string", "enum": ["buy", "add", "trim", "sell", "hold", "drop_from_watchlist"]},
          "entry_zone": {"type": "string"},
          "stop": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "rationale": {"type": "string"}
        }
      }
    },
    "market_note": {"type": "string"}
  }
}
