{
  "type": "object",
  "required": ["prey"],
  "properties": {
    "prey": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["symbol", "companyName", "confidence", "thesis", "horizon", "kill_criteria"],
        "properties": {
          "symbol":      {"type": "string"},
          "companyName": {"type": "string"},
          "anomalyType": {"type": "string", "const": "QUALITY_52W_LOW"},
          "confidence":  {"type": "number", "minimum": 0, "maximum": 1},
          "thesis":      {"type": "string"},
          "signals":     {"type": "array", "items": {"type": "string"}},
          "risks":       {"type": "array", "items": {"type": "string"}},
          "horizon":     {"type": "string", "enum": ["1m", "3m", "6m", "12m"]},
          "kill_criteria": {"type": "array", "items": {"type": "string"}, "minItems": 1, "maxItems": 5}
        }
      }
    }
  }
}
