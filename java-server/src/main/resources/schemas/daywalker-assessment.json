{
  "type": "object",
  "properties": {
    "symbol": { "type": "string" },
    "trigger_type": { "type": "string" },
    "severity": { "type": "string", "enum": ["INFO", "WARNING", "CRITICAL"] },
    "thesis": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "position_id": { "type": "string" },
    "event_type": { "type": "string", "enum": ["earnings_miss", "guidance_cut", "ma", "dilution", "restatement", "investigation", "macro", "other", "none"] },
    "news_sentiment": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["headline", "sentiment"],
        "properties": {
          "headline": { "type": "string" },
          "sentiment": { "type": "number", "minimum": -1, "maximum": 1 }
        }
      }
    }
  },
  "required": ["symbol", "trigger_type", "severity", "thesis", "confidence"]
}
