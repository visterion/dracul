    "vuetify": "^4.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "sass": "^1.100.0",
    "typescript": "^6.0.3",
