{
  "name": "chronicle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "type-check": "vue-tsc --noEmit",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:integration": "playwright test --config playwright.config.integration.ts",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@phosphor-icons/vue": "^2.2.0",
    "@phosphor-icons/web": "^2.1.2",
    "dompurify": "^3.4.12",
    "echarts": "^6.1.0",
    "marked": "^18.0.7",
    "pinia": "^3.0.4",
    "vue": "^3.5.40",
    "vue-echarts": "^8.0.1",
    "vue-i18n": "^11.4.7",
    "vue-router": "^5.2.0",
    "vuetify": "^4.1.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.11.0",
    "jsdom": "^29.1.1",
    "sass": "^1.101.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  }
}
